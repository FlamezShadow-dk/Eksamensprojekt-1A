<Window x:Class="SnapPexOverview.UILayer.ProduceMachineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnapPexOverview.UILayer"
        mc:Ignorable="d"
        Title="ProduceMachineWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- header? -->
        <TextBlock Grid.Row="0"
                   Text="Produktion af maskiner"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <!-- input stuff-->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <TextBlock Text="Antal maskiner:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>

            <TextBox Width="120"
                     Text="{Binding MachineAmountToProduce, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        
        <!-- buttons-->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button Content="Annuller"
                    Width="90"
                    Margin="5"
                    IsCancel="True"
                    Background="#FFE09595"/>

            <Button Content="Producer"
                    Width="90"
                    Margin="5"
                    IsDefault="True"
                    Click="OnProduceClick"
                    Background="#FFA9E095"/>
        </StackPanel>
    </Grid>
</Window>
