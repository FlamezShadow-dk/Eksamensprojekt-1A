<Window x:Class="SnapPexOverview.UILayer.ProduceMachineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnapPexOverview.UILayer"
        mc:Ignorable="d"
        Title="ProduceMachineWindow" Height="400" Width="400">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="120"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.ColumnSpan="2"
            Text="Produktion af Maskiner"
            FontSize="20"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" 
            Height="30"/>

        <!-- Input Fields -->
        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Text="Antal maskiner:"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0" Height="16"/>
        <TextBox Grid.Row="2"
                 Grid.Column="1"
                 Margin="5,10,5,10"
                 Text="{Binding MachineAmountToProduce, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Text="Produktion reference:"
                   VerticalAlignment="Center"
                   Margin="0,0,6,0" Height="16"/>
        <ComboBox Grid.Row="3"
                  Grid.Column="1"
                  Margin="5,10,5,10"
                  Text="{Binding ProductionReference, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- buttons-->
        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Width="200">
            <Button Content="Annuller"
                    Width="90"
                    Margin="5"
                    IsCancel="True"
                    Background="#FFE09595"/>

            <Button Content="Producer"
                    Width="90"
                    Margin="5"
                    IsDefault="True"
                    Click="OnProduceClick"
                    Background="#FFA9E095"/>
        </StackPanel>
    </Grid>
</Window>
