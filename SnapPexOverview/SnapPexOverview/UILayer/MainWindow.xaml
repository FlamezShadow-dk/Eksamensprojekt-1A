<Window x:Class="SnapPexOverview.UILayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnapPexOverview.UILayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ControlTemplate x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <TabControl Margin="10,10,10,10" BorderBrush="#FF626262">
            <TabItem Header="Komponent" BorderBrush="{x:Null}" Background="#FFDC7171">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56*"/>
                        <ColumnDefinition Width="331*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ComponentSearch" TextWrapping="Wrap" BorderBrush="#FFB3B3B3" Background="#FFB3B3B3" Text="Søg efter komponent" SelectionOpacity="1" Height="19" VerticalAlignment="Top" Grid.ColumnSpan="2"/>
                    <ListView ItemsSource="{Binding Components}" SelectedItem="{Binding SelectedComponent}" Margin="0,20,0,70" Foreground="Black" BorderBrush="{x:Null}" Background="#FFEDEDED" Grid.ColumnSpan="2">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Komponent" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding ImagePath}"
                                                       Width="60"
                                                       Height="60"
                                                       Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding ComponentName}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn 
                                       Header="Antal pr Maskine" 
                                       DisplayMemberBinding="{Binding AmountPerMachine}" 
                                       Width="150" />
                                <GridViewColumn 
                                       Header="Antal på Lager" 
                                       DisplayMemberBinding="{Binding AmountInStock}" 
                                       Width="150" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Button 
                        Content="Opdater Komponent"
                        Command="{Binding OpenUpdateComponentWindowCommand}"
                        Margin="0,0,10,10" 
                        Height="50" 
                        VerticalAlignment="Bottom" 
                        HorizontalAlignment="Right" 
                        Width="200" 
                        FontSize="20" 
                        BorderBrush="#FF569047" 
                        Background="#FF9DE28A" 
                        Grid.IsSharedSizeScope="True" 
                        FontFamily="Segoe UI Semibold" 
                        Template="{DynamicResource RoundedButton}" Grid.Column="1"/>
                    <Button 
                        Content="Tilføj Ny Komponent" 
                        Command="{Binding OpenAddComponentWindowCommand}" 
                        Margin="10,0,0,10" 
                        Height="50" 
                        VerticalAlignment="Bottom" 
                        FontSize="20" 
                        BorderBrush="#FF476B90" 
                        Background="#FF8AB2E2" 
                        Grid.IsSharedSizeScope="True" 
                        FontFamily="Segoe UI Semibold" 
                        Template="{DynamicResource RoundedButton}" 
                        HorizontalAlignment="Left" 
                        Width="200" Grid.ColumnSpan="2"/>

                </Grid>
            </TabItem>
            <TabItem Header="Maskine" Background="#FF71DC74">
                <Grid>
                    <TextBox Text="Søg maskine"
                             Height="19"
                             VerticalAlignment="Top"
                             BorderBrush="#FFB3B3B3"
                             Background="#FFB3B3B3"/>

                    <ListView ItemsSource="{Binding Machines}"
                              Margin="0,20,0,70"
                              Foreground="Black"
                              BorderBrush="Transparent"
                              Background="#FFEDEDED">

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Maskin Nr"
                                                DisplayMemberBinding="{Binding DisplayMachineNr}" 
                                                Width="250"/>
                                <GridViewColumn Header="Status"
                                                DisplayMemberBinding="{Binding StatusText}" 
                                                Width="250"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Button 
                        Content="Opdater Status" 
                        Margin="0,0,10,10" 
                        Height="50" 
                        VerticalAlignment="Bottom" 
                        HorizontalAlignment="Right" 
                        Width="200" FontSize="20" 
                        BorderBrush="#FF569047"
                        Background="#FF9DE28A" 
                        Grid.IsSharedSizeScope="True" 
                        FontFamily="Segoe UI Semibold" 
                        Template="{DynamicResource RoundedButton}" 
                        Click="Button_Click" 
                        Grid.Column="1"/>
                    <Button 
                        Content="Tilføj Ny Maskine" 
                        Command="{Binding OpenProduceMachineWindowCommand}" 
                        Margin="10,0,0,10" 
                        Height="50" 
                        VerticalAlignment="Bottom" 
                        FontSize="20" 
                        BorderBrush="#FF476B90" 
                        Background="#FF8AB2E2" 
                        Grid.IsSharedSizeScope="True" 
                        FontFamily="Segoe UI Semibold" 
                        Template="{DynamicResource RoundedButton}" 
                        HorizontalAlignment="Left" 
                        Width="200" 
                        Grid.ColumnSpan="2"/>
                </Grid>
            </TabItem>
            <TabItem Header="Udlejning" Background="#FF71B1DC">
                <Grid>
                    <TextBox Text="Søg Udlejning"
                             Height="19"
                             VerticalAlignment="Top"
                             BorderBrush="#FFB3B3B3"
                             Background="#FFB3B3B3"/>
                    <ListView ItemsSource="{Binding Rental}"
                              Margin="0,20,0,70"
                              Foreground="Black"
                              BorderBrush="Transparent"
                              Background="#FFEDEDED">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Firma-Navn"
                                                DisplayMemberBinding="{Binding DisplayRentalCompany}"
                                                Width="300"/>
                                <GridViewColumn Header="# Maskiner Lejet"
                                                DisplayMemberBinding="{Binding NumberOfMachines}" 
                                                Width="150"/>
                                <GridViewColumn Header="Udlejning Start"
                                                DisplayMemberBinding="{Binding RentalPeriodStart}" 
                                                Width="250"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Button Content="Opdater Udlejning" 
                            Margin="0,0,10,10" 
                            Height="50"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Width="200" FontSize="20"
                            BorderBrush="#FF569047"
                            Background="#FF9DE28A"
                            Grid.IsSharedSizeScope="True"
                            FontFamily="Segoe UI Semibold"
                            Template="{DynamicResource RoundedButton}"
                            Click="Button_Click"
                            Grid.Column="1"/>
                    <Button Content="Tilføj Ny Udlejning" 
                            Margin="10,0,0,10" 
                            Height="50" 
                            VerticalAlignment="Bottom" 
                            FontSize="20" 
                            BorderBrush="#FF476B90" 
                            Background="#FF8AB2E2" 
                            Grid.IsSharedSizeScope="True" 
                            FontFamily="Segoe UI Semibold" 
                            Template="{DynamicResource RoundedButton}" 
                            HorizontalAlignment="Left" 
                            Width="200" 
                            Grid.ColumnSpan="2"/>
                </Grid>
            </TabItem>
            <TabItem Header="Skruer" Background="#FFCF71DC">
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Tilføj Nye Skruer" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="30" 
                           FontWeight="Bold"
                           Grid.ColumnSpan="2"
                           Height="50"/>

                    <Border Background="#FFDFDFDF"
                            Grid.Row="1"
                            Grid.Column="0"
                            Height="120"
                            Width="120"/>
                    <CheckBox x:Name="_16mmCheck"
                              VerticalAlignment="Top"
                              Margin="20,5,0,0"
                              Grid.Row="1"
                              Grid.Column="0" 
                              Grid.ColumnSpan="2" 
                              Height="15"/>
                    <Label Content="16mm Hoved" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Width="100" 
                           FontWeight="Bold"
                           Grid.Row="2" Height="26"/>


                    <Border Background="#FFDFDFDF"
                            Grid.Row="1"
                            Grid.Column="1"
                            Height="120"
                            Width="120"/>
                    <CheckBox x:Name="_18mmCheck"
                              VerticalAlignment="Top"
                              Margin="20,5,0,0"
                              Grid.Row="1"
                              Grid.Column="1" Height="15"/>
                    <Label Content="18mm Hoved" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" 
                           Width="100" 
                           FontWeight="Bold"
                           Grid.Row="2"
                           Grid.Column="1" Height="26"/>

                    <Label Content="Hvor Mange Nye?" 
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Width="114"
                           FontWeight="Bold"
                           Grid.Row="3"
                           Grid.ColumnSpan="2" 
                           Height="30"/>

                    <TextBox x:Name="ScrewSearch"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center" 
                             TextWrapping="Wrap" 
                             BorderBrush="#FF787878" 
                             Background="#FFE2E2E2"
                             Height="20"
                             MinWidth="150"
                             Grid.Row="4"
                             Grid.ColumnSpan="2"/>

                    <Button Content="Godkend"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Height="50"
                            Width="125" 
                            FontSize="24" 
                            BorderBrush="#FF569047" 
                            Background="#FF9DE28A" 
                            Grid.IsSharedSizeScope="True" 
                            FontFamily="Segoe UI Semibold" 
                            Template="{DynamicResource RoundedButton}"
                            Grid.Row="5"
                            Grid.ColumnSpan="2"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
