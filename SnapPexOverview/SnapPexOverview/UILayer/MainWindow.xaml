<Window x:Class="SnapPexOverview.UILayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnapPexOverview.UILayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ControlTemplate x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <TabControl Margin="10,10,10,10" BorderBrush="#FF626262">
            <TabItem Header="Komponent" BorderBrush="{x:Null}" Background="#FFDC7171">
                <Grid>
                    <TextBox x:Name="ComponentSearch" TextWrapping="Wrap" BorderBrush="#FFB3B3B3" Background="#FFB3B3B3" Text="Søg efter komponent" SelectionOpacity="1" Height="19" VerticalAlignment="Top"/>
                    <ListView Name="ComponentView" ItemsSource="{d:SampleData ItemCount=5}" Margin="0,20,0,70" Foreground="Black" BorderBrush="{x:Null}" Background="#FFEDEDED">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Komponent" DisplayMemberBinding="{Binding Komponent}" Width="300" />
                                <GridViewColumn Header="Antal på Lager" DisplayMemberBinding="{Binding påLager}" Width="150" />
                                <GridViewColumn Header="Antal pr Maskine" DisplayMemberBinding="{Binding prMaskine}" Width="150" />
                                <GridViewColumn Header="Antal lige Brugt" DisplayMemberBinding="{Binding AntalBrugt}" Width="150" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}"/>
                </Grid>
            </TabItem>
            <TabItem Header="Maskine" Background="#FF71DC74"/>
            <TabItem Header="Udlejning" Background="#FF71B1DC"/>
            <TabItem Header="Skruer" Background="#FFCF71DC"/>
        </TabControl>
    </Grid>
</Window>
