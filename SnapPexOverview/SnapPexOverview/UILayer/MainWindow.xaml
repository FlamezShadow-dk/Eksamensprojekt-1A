<Window x:Class="SnapPexOverview.UILayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnapPexOverview.UILayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ControlTemplate x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="6" Opacity="0.8"/>
                </Border.Effect>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <Button Content="Godkend" Margin="0,0,25,25" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold"/>
        <Grid Margin="25,40,25,100">
            <TextBox x:Name="ComponentSearch" TextWrapping="Wrap" BorderBrush="Gainsboro" Background="#FFB3B3B3" Text="Søg efter komponent" SelectionOpacity="1" Height="19" VerticalAlignment="Top"/>
            <ScrollViewer x:Name="ComponentView" Margin="0,20,0,0" Background="Gainsboro"/>
        </Grid>
    </Grid>
</Window>
