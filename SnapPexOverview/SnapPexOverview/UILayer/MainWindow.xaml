<Window x:Class="SnapPexOverview.UILayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnapPexOverview.UILayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ControlTemplate x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <TabControl Margin="10,10,10,10" BorderBrush="#FF626262">
            <TabItem Header="Komponent" BorderBrush="{x:Null}" Background="#FFDC7171">
                <Grid>
                    <TextBox x:Name="ComponentSearch" TextWrapping="Wrap" BorderBrush="#FFB3B3B3" Background="#FFB3B3B3" Text="Søg efter komponent" SelectionOpacity="1" Height="19" VerticalAlignment="Top"/>
                    <ListView ItemsSource="{Binding Components}" SelectedItem="{Binding SelectedComponent}" Margin="0,20,0,70" Foreground="Black" BorderBrush="{x:Null}" Background="#FFEDEDED">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Komponent" Width="400">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding ImagePath}"
                                                       Width="60"
                                                       Height="60"
                                                       Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding ComponentName}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn 
                                       Header="Antal pr Maskine" 
                                       DisplayMemberBinding="{Binding AmountPerMachine}" 
                                       Width="150" />
                                <GridViewColumn 
                                       Header="Antal på Lager" 
                                       DisplayMemberBinding="{Binding AmountInStock}" 
                                       Width="150" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Button 
                        Content="Opdater Komponent"
                        Command="{Binding OpenUpdateComponentWindowCommand}"
                        Margin="0,0,10,10" 
                        Height="50" 
                        VerticalAlignment="Bottom" 
                        HorizontalAlignment="Right" 
                        Width="200" 
                        FontSize="20" 
                        BorderBrush="#FF569047" 
                        Background="#FF9DE28A" 
                        Grid.IsSharedSizeScope="True" 
                        FontFamily="Segoe UI Semibold" 
                        Template="{DynamicResource RoundedButton}"/>
                    <Button 
                        Content="Tilføj Ny Komponent" 
                        Command="{Binding OpenAddComponentWindowCommand}" 
                        Margin="10,0,0,10" 
                        Height="50" 
                        VerticalAlignment="Bottom" 
                        FontSize="20" 
                        BorderBrush="#FF476B90" 
                        Background="#FF8AB2E2" 
                        Grid.IsSharedSizeScope="True" 
                        FontFamily="Segoe UI Semibold" 
                        Template="{DynamicResource RoundedButton}" 
                        HorizontalAlignment="Left" 
                        Width="200"/>
                </Grid>
            </TabItem>
            <TabItem Header="Maskine" Background="#FF71DC74">
                <Grid>
                    <TextBox Text="Søg maskine"
                             Height="19"
                             VerticalAlignment="Top"
                             BorderBrush="#FFB3B3B3"
                             Background="#FFB3B3B3"/>
                    
                    <ListView ItemsSource="{Binding Machines}"
                              Margin="0,20,0,70"
                              Foreground="Black"
                              BorderBrush="Transparent"
                              Background="#FFEDEDED">
                        
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Maskin Nr"
                                                DisplayMemberBinding="{Binding MachineNr}" 
                                                Width="250"/>
                                <GridViewColumn Header="Status"
                                                DisplayMemberBinding="{Binding StatusText}" 
                                                Width="250"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}"/>
                    <Button Content="Tilføj Ny" Command="{Binding OpenProduceMachineWindowCommand}" Margin="10,0,0,10" Height="50" VerticalAlignment="Bottom" FontSize="24" BorderBrush="#FF476B90" Background="#FF8AB2E2" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}" HorizontalAlignment="Left" Width="125"/>
                </Grid>
            </TabItem>
            <TabItem Header="Udlejning" Background="#FF71B1DC">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8*"/>
                        <ColumnDefinition Width="379*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}" Grid.Column="1"/>
                </Grid>
            </TabItem>
            <TabItem Header="Skruer" Background="#FFCF71DC">
                <Grid>
                    <Label Content="Tilføj Nye Skruer" Margin="262,45,262,0" VerticalAlignment="Top" FontSize="30" FontWeight="Bold"/>
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}"/>
                    <CheckBox x:Name="_16mmCheck" Margin="145,130,575,0" VerticalAlignment="Top"/>
                    <CheckBox x:Name="_18mmCheck"  Margin="575,130,145,0" VerticalAlignment="Top"/>
                    <Label Content="16mm Hoved" HorizontalAlignment="Left" Margin="135,220,0,0" VerticalAlignment="Top" Width="100" FontWeight="Bold"/>
                    <Label Content="18mm Hoved" HorizontalAlignment="Left" Margin="565,220,0,0" VerticalAlignment="Top" Width="100" FontWeight="Bold"/>
                    <Label Content="Hvor Mange Nye?" HorizontalAlignment="Center" Margin="0,250,0,0" VerticalAlignment="Top" Width="114" FontWeight="Bold"/>
                    <TextBox x:Name="ComponentSearch_Copy" TextWrapping="Wrap" BorderBrush="#FF787878" Background="#FFE2E2E2" SelectionOpacity="1" Height="19" VerticalAlignment="Top" Margin="262,280,262,0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
