<Window x:Class="SnapPexOverview.UILayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SnapPexOverview.UILayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ControlTemplate x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Border CornerRadius="10" Background="{TemplateBinding Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <TabControl Margin="10,10,10,10" BorderBrush="#FF626262">
            <TabItem Header="Komponent" BorderBrush="{x:Null}" Background="#FFDC7171">
                <Grid>
                    <TextBox x:Name="ComponentSearch" TextWrapping="Wrap" BorderBrush="#FFB3B3B3" Background="#FFB3B3B3" Text="Søg efter komponent" SelectionOpacity="1" Height="19" VerticalAlignment="Top"/>
                    <ListView ItemsSource="{Binding Components}" Margin="0,20,0,70" Foreground="Black" BorderBrush="{x:Null}" Background="#FFEDEDED">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Komponent" DisplayMemberBinding="{Binding ComponentName}" Width="300" />
                                <GridViewColumn Header="Antal på Lager" DisplayMemberBinding="{Binding AmountInStock}" Width="150" />
                                <GridViewColumn Header="Antal pr Maskine" DisplayMemberBinding="{Binding AmountPerMachine}" Width="150" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <!-- TODO: add command binding for opening this dialog -->
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}"/>
                    <Button Content="Tilføj Ny" Command="{Binding OpenAddComponentWindowCommand}" Margin="10,0,0,10" Height="50" VerticalAlignment="Bottom" FontSize="24" BorderBrush="#FF476B90" Background="#FF8AB2E2" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}" HorizontalAlignment="Left" Width="125"/>
                </Grid>
            </TabItem>
            <TabItem Header="Maskine" Background="#FF71DC74">
                <Grid>
                    <TextBox x:Name="MachineSearch" TextWrapping="Wrap" BorderBrush="#FFB3B3B3" Background="#FFB3B3B3" Text="Søg efter Maskine" SelectionOpacity="1" Height="19" VerticalAlignment="Top"/>
                    <ListView x:Name="MachineView" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,20,0,70" Foreground="Black" BorderBrush="{x:Null}" Background="#FFEDEDED">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Maskine" DisplayMemberBinding="{Binding Maskine}" Width="200" />
                                <GridViewColumn Header="Udlejet hos" DisplayMemberBinding="{Binding Udlejning}" Width="400" />
                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="150" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}"/>
                    <Button Content="Tilføj Ny" Margin="10,0,0,10" Height="50" VerticalAlignment="Bottom" FontSize="24" BorderBrush="#FF476B90" Background="#FF8AB2E2" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}" HorizontalAlignment="Left" Width="125"/>
                </Grid>
            </TabItem>
            <TabItem Header="Udlejning" Background="#FF71B1DC">
                <Grid>
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}"/>
                </Grid>
            </TabItem>
            <TabItem Header="Skruer" Background="#FFCF71DC">
                <Grid>
                    <Label Content="Tilføj Nye Skruer" Margin="262,45,262,0" VerticalAlignment="Top" FontSize="30" FontWeight="Bold"/>
                    <Button Content="Godkend" Margin="0,0,10,10" Height="50" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="125" FontSize="24" BorderBrush="#FF569047" Background="#FF9DE28A" Grid.IsSharedSizeScope="True" FontFamily="Segoe UI Semibold" Template="{DynamicResource RoundedButton}"/>
                    <Image HorizontalAlignment="Left" Height="100" Margin="135,120,0,0" VerticalAlignment="Top" Width="100" Source="/UILayer/placeholder.png"/>
                    <CheckBox x:Name="_16mmCheck" Margin="145,130,575,0" VerticalAlignment="Top"/>
                    <Image HorizontalAlignment="Left" Height="100" Margin="565,120,0,0" VerticalAlignment="Top" Width="100" Source="/UILayer/placeholder.png"/>
                    <CheckBox x:Name="_18mmCheck"  Margin="575,130,145,0" VerticalAlignment="Top"/>
                    <Label Content="16mm Hoved" HorizontalAlignment="Left" Margin="135,220,0,0" VerticalAlignment="Top" Width="100" FontWeight="Bold"/>
                    <Label Content="18mm Hoved" HorizontalAlignment="Left" Margin="565,220,0,0" VerticalAlignment="Top" Width="100" FontWeight="Bold"/>
                    <Label Content="Hvor Mange Nye?" HorizontalAlignment="Center" Margin="0,250,0,0" VerticalAlignment="Top" Width="114" FontWeight="Bold"/>
                    <TextBox x:Name="ComponentSearch_Copy" TextWrapping="Wrap" BorderBrush="#FF787878" Background="#FFE2E2E2" SelectionOpacity="1" Height="19" VerticalAlignment="Top" Margin="262,280,262,0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
